@model List<Book>
@{
    ViewData["Title"] = "Родина в книгах";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Forest Scene Background -->
<div class="forest-scene">
    <svg class="forest-svg" viewBox="0 0 1440 320" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMax slice">
        <!-- Far background trees (pale) -->
        <g opacity="0.18" fill="#3a5c32">
            <polygon points="80,280 110,180 140,280"/>
            <polygon points="100,280 110,150 120,280"/>
            <polygon points="200,280 235,165 270,280"/>
            <polygon points="220,280 235,140 250,280"/>
            <polygon points="380,280 410,170 440,280"/>
            <polygon points="560,280 595,160 630,280"/>
            <polygon points="720,280 755,155 790,280"/>
            <polygon points="900,280 930,168 960,280"/>
            <polygon points="1050,280 1085,162 1120,280"/>
            <polygon points="1200,280 1230,170 1260,280"/>
            <polygon points="1350,280 1380,158 1410,280"/>
        </g>
        <!-- Mid trees -->
        <g opacity="0.32" fill="#3a5c32">
            <polygon points="0,300 40,175 80,300"/>
            <polygon points="15,300 40,148 65,300"/>
            <polygon points="130,300 165,178 200,300"/>
            <polygon points="145,300 165,152 185,300"/>
            <polygon points="290,300 330,172 370,300"/>
            <polygon points="460,300 500,165 540,300"/>
            <polygon points="640,300 680,170 720,300"/>
            <polygon points="820,300 855,158 890,300"/>
            <polygon points="980,300 1015,163 1050,300"/>
            <polygon points="1130,300 1165,175 1200,300"/>
            <polygon points="1280,300 1315,160 1350,300"/>
            <polygon points="1400,300 1430,172 1460,300"/>
        </g>
        <!-- Foreground birch silhouettes -->
        <g fill="#e8dfd0" opacity="0.55">
            <!-- Left birch cluster -->
            <rect x="32" y="120" width="11" height="200" rx="4"/>
            <rect x="52" y="90" width="13" height="230" rx="4"/>
            <ellipse cx="37" cy="140" rx="5" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="37" cy="180" rx="6" ry="2.5" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="37" cy="225" rx="5" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="58" cy="120" rx="6" ry="2.5" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="58" cy="165" rx="7" ry="2.5" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="58" cy="215" rx="6" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="58" cy="265" rx="5" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <!-- Right birch cluster -->
            <rect x="1378" y="105" width="13" height="220" rx="4"/>
            <rect x="1398" y="130" width="10" height="195" rx="4"/>
            <ellipse cx="1384" cy="130" rx="6" ry="2.5" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="1384" cy="175" rx="7" ry="2.5" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="1384" cy="220" rx="6" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="1384" cy="265" rx="5" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="1403" cy="155" rx="5" ry="2" fill="#2a2a2a" opacity="0.5"/>
            <ellipse cx="1403" cy="200" rx="6" ry="2" fill="#2a2a2a" opacity="0.5"/>
        </g>
        <!-- Front pine trees (darkest) -->
        <g fill="#2d4a25" opacity="0.45">
            <polygon points="-10,320 22,220 54,320"/>
            <polygon points="5,320 22,195 39,320"/>
            <polygon points="1390,320 1420,210 1450,320"/>
            <polygon points="1405,320 1420,185 1435,320"/>
        </g>
        <!-- Ground -->
        <rect x="0" y="300" width="1440" height="20" fill="#3a5c32" opacity="0.12"/>
    </svg>
</div>

<div class="site-wrapper">
    <!-- HEADER -->
    <header class="site-header">
        <div class="header-inner">
            <div class="birch-decoration left">
                <svg viewBox="0 0 60 320" xmlns="http://www.w3.org/2000/svg" class="birch-tree">
                    <rect x="22" y="0" width="16" height="320" fill="#f5f0e8" rx="4"/>
                    <ellipse cx="30" cy="25" rx="8" ry="3" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="70" rx="10" ry="4" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="120" rx="9" ry="3.5" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="175" rx="10" ry="4" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="230" rx="8" ry="3" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="280" rx="10" ry="4" fill="#2a2a2a" opacity="0.18"/>
                    <!-- Branches left -->
                    <line x1="22" y1="80" x2="5" y2="65" stroke="#d4c8b8" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="22" y1="140" x2="2" y2="122" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                    <line x1="22" y1="200" x2="6" y2="186" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                    <!-- Branches right -->
                    <line x1="38" y1="100" x2="55" y2="85" stroke="#d4c8b8" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="38" y1="160" x2="58" y2="144" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                    <line x1="38" y1="220" x2="54" y2="205" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>

            <div class="header-content">
                <div class="georgibon-3d">
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                </div>
                <h1 class="site-title">Родина в книгах</h1>
                <p class="site-subtitle">Литература, которая хранит душу народа</p>
                <div class="georgibon-3d">
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                </div>
            </div>

            <div class="birch-decoration right">
                <svg viewBox="0 0 60 320" xmlns="http://www.w3.org/2000/svg" class="birch-tree">
                    <rect x="22" y="0" width="16" height="320" fill="#f5f0e8" rx="4"/>
                    <ellipse cx="30" cy="25" rx="8" ry="3" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="70" rx="10" ry="4" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="120" rx="9" ry="3.5" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="175" rx="10" ry="4" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="230" rx="8" ry="3" fill="#2a2a2a" opacity="0.18"/>
                    <ellipse cx="30" cy="280" rx="10" ry="4" fill="#2a2a2a" opacity="0.18"/>
                    <line x1="22" y1="80" x2="5" y2="65" stroke="#d4c8b8" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="22" y1="140" x2="2" y2="122" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                    <line x1="22" y1="200" x2="6" y2="186" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                    <line x1="38" y1="100" x2="55" y2="85" stroke="#d4c8b8" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="38" y1="160" x2="58" y2="144" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                    <line x1="38" y1="220" x2="54" y2="205" stroke="#d4c8b8" stroke-width="2" stroke-linecap="round"/>
                </svg>
            </div>
        </div>
    </header>

    <!-- FILTER BAR -->
    <div class="filter-bar">
        <div class="filter-inner">
            <button class="filter-btn active" data-genre="all">Все книги</button>
            <button class="filter-btn" data-genre="Роман-эпопея">Роман-эпопея</button>
            <button class="filter-btn" data-genre="Военная проза">Военная проза</button>
            <button class="filter-btn" data-genre="Историческая повесть">Историческая повесть</button>
            <button class="filter-btn" data-genre="Рассказ">Рассказ</button>
            <button class="filter-btn" data-genre="Документальная проза">Документальная проза</button>
        </div>
    </div>

    <!-- BOOKS GRID -->
    <main class="books-section">
        <div class="books-grid" id="booksGrid">
            @foreach (var book in Model)
            {
                <div class="book-card @(book.IsFeatured ? "featured" : "")"
                     data-genre="@book.Genre"
                     data-id="@book.Id"
                     data-has-text="@(book.BookText != null && book.BookText.Length > 0 ? "true" : "false")">
                    <div class="book-card-inner">
                        <!-- FRONT -->
                        <div class="book-front">
                            <div class="book-image-wrap">
                                @if (book.ImagePath != null)
                                {
                                    <img src="@book.ImagePath" alt="@book.Title" class="book-cover-img" loading="lazy"/>
                                }
                                else
                                {
                                    <div class="book-cover-placeholder">
                                        <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg">
                                            <rect width="80" height="100" rx="4" fill="#e8dfd0"/>
                                            <rect x="8" y="15" width="64" height="3" rx="1" fill="#c4a882"/>
                                            <rect x="8" y="25" width="50" height="3" rx="1" fill="#c4a882"/>
                                            <rect x="8" y="40" width="64" height="2" rx="1" fill="#d4c4b0"/>
                                            <rect x="8" y="48" width="64" height="2" rx="1" fill="#d4c4b0"/>
                                            <rect x="8" y="56" width="48" height="2" rx="1" fill="#d4c4b0"/>
                                            <path d="M30 72 Q40 62 50 72 Q40 82 30 72Z" fill="#c4a882"/>
                                        </svg>
                                    </div>
                                }
                                @if (book.IsFeatured)
                                {
                                    <div class="featured-badge">⭐ Избранное</div>
                                }
                            </div>
                            <div class="book-meta">
                                <span class="book-genre-tag">@book.Genre</span>
                                <h3 class="book-title">@book.Title</h3>
                                <p class="book-author">@book.Author · @book.Year</p>
                                <p class="book-short-desc">@book.ShortDescription</p>
                            </div>
                            <div class="book-actions">
                                <button class="expand-btn">Подробнее →</button>
                                @if (book.BookText != null && book.BookText.Length > 0)
                                {
                                    <button class="read-btn" data-id="@book.Id">📖 Читать</button>
                                }
                                else
                                {
                                    <button class="read-btn disabled" disabled>📖 Нет текста</button>
                                }
                            </div>
                        </div>

                        <!-- EXPANDED -->
                        <div class="book-expanded" id="expanded-@book.Id" style="display:none;">
                            <button class="collapse-btn">← Назад</button>
                            <div class="expanded-content">
                                <div class="expanded-left">
                                    @if (book.ImagePath != null)
                                    {
                                        <img src="@book.ImagePath" alt="@book.Title" class="expanded-cover-img"/>
                                    }
                                    else
                                    {
                                        <div class="book-cover-placeholder large">
                                            <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg">
                                                <rect width="80" height="100" rx="4" fill="#e8dfd0"/>
                                                <path d="M30 72 Q40 62 50 72 Q40 82 30 72Z" fill="#c4a882"/>
                                            </svg>
                                        </div>
                                    }
                                </div>
                                <div class="expanded-right">
                                    <span class="book-genre-tag">@book.Genre</span>
                                    <h2 class="expanded-title">@book.Title</h2>
                                    <p class="expanded-author">@book.Author · @book.Year</p>
                                    <div class="divider-leaf">🍂</div>
                                    <p class="expanded-desc">@book.Description</p>
                                    @if (!string.IsNullOrEmpty(book.Tags))
                                    {
                                        <div class="tags-row">
                                            @foreach (var tag in book.Tags.Split(','))
                                            {
                                                <span class="tag">#@tag.Trim()</span>
                                            }
                                        </div>
                                    }
                                    @if (book.BookText != null && book.BookText.Length > 0)
                                    {
                                        <button class="read-btn" data-id="@book.Id" style="margin-top:14px; width:100%;">📖 Читать книгу</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="georgibon-3d footer-ribbon">
            <div class="ribbon-stripe-3d black"></div>
            <div class="ribbon-stripe-3d orange"></div>
            <div class="ribbon-stripe-3d black"></div>
            <div class="ribbon-stripe-3d orange"></div>
            <div class="ribbon-stripe-3d black"></div>
        </div>
        <p>© 2026 Родина в книгах — хранитель литературного наследия</p>
    </footer>
</div>

<!-- READER MODAL -->
<div class="reader-overlay" id="readerOverlay">
    <div class="reader-modal" id="readerModal">
        <div class="reader-header">
            <div>
                <div class="reader-book-title" id="readerTitle">Название книги</div>
                <div class="reader-book-author" id="readerAuthor">Автор</div>
            </div>
            <button class="reader-close" id="readerClose" title="Закрыть">✕</button>
        </div>
        <div class="reader-toolbar">
            <div class="reader-font-ctrl">
                <span>Шрифт</span>
                <button class="reader-font-btn" id="fontMinus">A−</button>
                <button class="reader-font-btn" id="fontPlus">A+</button>
            </div>
            <button class="reader-theme-btn active" data-theme="sepia">Сепия</button>
            <button class="reader-theme-btn" data-theme="light">Светлая</button>
            <button class="reader-theme-btn" data-theme="dark">Тёмная</button>
            <span class="reader-progress-info" id="readerProgress">Страница 1 из 1</span>
        </div>
        <div class="reader-body">
            <div class="reader-content theme-sepia" id="readerContent">
                <div class="loading-overlay" id="readerLoading">
                    <div class="spinner"></div>
                </div>
            </div>
        </div>
        <div class="reader-pages">
            <button class="page-nav-btn" id="prevPage" disabled>← Назад</button>
            <div class="page-indicator">
                <div class="page-dots" id="pageDots"></div>
            </div>
            <button class="page-nav-btn" id="nextPage">Вперёд →</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/main.js"></script>
}
