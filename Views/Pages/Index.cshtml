@model List<Book>
@{
    ViewData["Title"] = "Родина в книгах";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="site-wrapper">
    <!-- HEADER -->
    <header class="site-header">
        <div class="ribbon-top-3d"></div>  <!-- новая 3D верхняя лента -->
        <div class="header-inner">
            <div class="birch-decoration left">
                <svg viewBox="0 0 60 300" xmlns="http://www.w3.org/2000/svg" class="birch-tree">
                    <rect x="22" y="0" width="16" height="300" fill="#f5f0e8" rx="3"/>
                    <ellipse cx="30" cy="20" rx="8" ry="3" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="60" rx="10" ry="4" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="110" rx="8" ry="3" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="160" rx="9" ry="4" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="210" rx="8" ry="3" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="260" rx="10" ry="4" fill="#2a2a2a" opacity="0.15"/>
                </svg>
            </div>

            <div class="header-content">
                <!-- КРУТАЯ 3D ЛЕНТА (верхняя) -->
                <div class="georgibon-3d">
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                </div>

                <h1 class="site-title">Родина в книгах</h1>
                <p class="site-subtitle">Литература, которая хранит душу народа</p>

                <!-- КРУТАЯ 3D ЛЕНТА (нижняя) -->
                <div class="georgibon-3d">
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                    <div class="ribbon-stripe-3d orange"></div>
                    <div class="ribbon-stripe-3d black"></div>
                </div>
            </div>

            <div class="birch-decoration right">
                <svg viewBox="0 0 60 300" xmlns="http://www.w3.org/2000/svg" class="birch-tree">
                    <rect x="22" y="0" width="16" height="300" fill="#f5f0e8" rx="3"/>
                    <ellipse cx="30" cy="20" rx="8" ry="3" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="60" rx="10" ry="4" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="110" rx="8" ry="3" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="160" rx="9" ry="4" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="210" rx="8" ry="3" fill="#2a2a2a" opacity="0.15"/>
                    <ellipse cx="30" cy="260" rx="10" ry="4" fill="#2a2a2a" opacity="0.15"/>
                </svg>
            </div>
        </div>
    </header>

    <!-- FILTER BAR -->
    <div class="filter-bar">
        <div class="filter-inner">
            <button class="filter-btn active" data-genre="all">Все книги</button>
            <button class="filter-btn" data-genre="Роман-эпопея">Роман-эпопея</button>
            <button class="filter-btn" data-genre="Военная проза">Военная проза</button>
            <button class="filter-btn" data-genre="Историческая повесть">Историческая повесть</button>
            <button class="filter-btn" data-genre="Рассказ">Рассказ</button>
            <button class="filter-btn" data-genre="Документальная проза">Документальная проза</button>
        </div>
    </div>

    <!-- BOOKS GRID -->
    <main class="books-section">
        <div class="books-grid" id="booksGrid">
            @foreach (var book in Model)
            {
                <div class="book-card @(book.IsFeatured ? "featured" : "")" 
                     data-genre="@book.Genre" 
                     data-id="@book.Id">
                    <div class="book-card-inner">
                        <!-- FRONT -->
                        <div class="book-front">
                            <div class="book-image-wrap">
                                @if (book.ImagePath != null)
                                {
                                    <img src="@book.ImagePath" alt="@book.Title" class="book-cover-img" loading="lazy"/>
                                }
                                else
                                {
                                    <div class="book-cover-placeholder">
                                        <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg">
                                            <rect width="80" height="100" rx="4" fill="#e8dfd0"/>
                                            <rect x="8" y="15" width="64" height="3" rx="1" fill="#c4a882"/>
                                            <rect x="8" y="25" width="50" height="3" rx="1" fill="#c4a882"/>
                                            <rect x="8" y="40" width="64" height="2" rx="1" fill="#d4c4b0"/>
                                            <rect x="8" y="48" width="64" height="2" rx="1" fill="#d4c4b0"/>
                                            <rect x="8" y="56" width="48" height="2" rx="1" fill="#d4c4b0"/>
                                            <path d="M30 72 Q40 62 50 72 Q40 82 30 72Z" fill="#c4a882"/>
                                        </svg>
                                    </div>
                                }
                                @if (book.IsFeatured)
                                {
                                    <div class="featured-badge">⭐ Избранное</div>
                                }
                            </div>
                            <div class="book-meta">
                                <span class="book-genre-tag">@book.Genre</span>
                                <h3 class="book-title">@book.Title</h3>
                                <p class="book-author">@book.Author · @book.Year</p>
                                <p class="book-short-desc">@book.ShortDescription</p>
                                <button class="expand-btn">Читать подробнее →</button>
                            </div>
                        </div>

                        <!-- EXPANDED -->
                        <div class="book-expanded" id="expanded-@book.Id" style="display:none;">
                            <button class="collapse-btn">← Назад</button>
                            <div class="expanded-content">
                                <div class="expanded-left">
                                    @if (book.ImagePath != null)
                                    {
                                        <img src="@book.ImagePath" alt="@book.Title" class="expanded-cover-img"/>
                                    }
                                    else
                                    {
                                        <div class="book-cover-placeholder large">
                                            <svg viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg">
                                                <rect width="80" height="100" rx="4" fill="#e8dfd0"/>
                                                <rect x="8" y="15" width="64" height="3" rx="1" fill="#c4a882"/>
                                                <rect x="8" y="25" width="50" height="3" rx="1" fill="#c4a882"/>
                                                <rect x="8" y="40" width="64" height="2" rx="1" fill="#d4c4b0"/>
                                                <rect x="8" y="48" width="64" height="2" rx="1" fill="#d4c4b0"/>
                                                <rect x="8" y="56" width="48" height="2" rx="1" fill="#d4c4b0"/>
                                                <path d="M30 72 Q40 62 50 72 Q40 82 30 72Z" fill="#c4a882"/>
                                            </svg>
                                        </div>
                                    }
                                </div>
                                <div class="expanded-right">
                                    <span class="book-genre-tag">@book.Genre</span>
                                    <h2 class="expanded-title">@book.Title</h2>
                                    <p class="expanded-author">@book.Author · @book.Year</p>
                                    <div class="divider-leaf">🍂</div>
                                    <p class="expanded-desc">@book.Description</p>
                                    @if (!string.IsNullOrEmpty(book.Tags))
                                    {
                                        <div class="tags-row">
                                            @foreach (var tag in book.Tags.Split(','))
                                            {
                                                <span class="tag">#@tag.Trim()</span>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
        <div class="georgibon-3d footer-ribbon">
            <div class="ribbon-stripe-3d black"></div>
            <div class="ribbon-stripe-3d orange"></div>
            <div class="ribbon-stripe-3d black"></div>
            <div class="ribbon-stripe-3d orange"></div>
            <div class="ribbon-stripe-3d black"></div>
        </div>
        <p>© 2026 Родина в книгах — хранитель литературного наследия</p>
    </footer>
</div>

@section Scripts {
    <script src="/js/main.js"></script>
}
