<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Русская Библиотека</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Raleway:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <!-- Фоновые деревья и ветки -->
<div class="forest-bg">
    <div class="tree birch left-birch-1"></div>
    <div class="tree birch left-birch-2"></div>
    <div class="tree birch right-birch-1"></div>
    <div class="tree birch right-birch-2"></div>
    <div class="tree oak left-oak"></div>
    <div class="tree oak right-oak"></div>
    <div class="branches"></div>
</div>
    <canvas id="leafCanvas"></canvas>
    @RenderBody()
    <script src="/js/leaves.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
